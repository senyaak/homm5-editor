{
  "name": "homm5-editor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Experimental map/campaign editor for Heroes of Might and Magic 5 (Tribes of the East)",
  "main": "electron/main.ts",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "inspect": "node tools/inspect-terrain.js",
    "test-terrain": "node tools/test-terrain.js",
    "test-terrain-write": "node tools/test-terrain-write.ts",
    "test-terrain-blank": "node tools/test-terrain-blank.ts",
    "test-blank-map": "node tools/test-blank-map.ts",
    "test-new-map": "node tools/test-new-map.ts",
    "test-terrain-layer": "node tools/test-terrain-layer.ts",
    "test-terrain-plane": "node tools/test-terrain-plane.ts",
    "test-pak": "node tools/test-pak.js",
    "test-map": "node tools/test-map.js",
    "test-watch": "node tools/test-watch.ts",
    "mesh-audit": "node tools/mesh-audit.ts",
    "test-objects": "node tools/test-objects.ts",
    "test-scene": "node tools/test-scene.ts",
    "test-registry": "node tools/test-registry.ts",
    "test-schema": "node tools/test-schema.ts",
    "test-objects-schema": "node tools/test-objects-schema.ts",
    "test-tree": "node tools/test-tree.ts",
    "test-lua-lint": "node tools/test-lua-lint.ts",
    "test-history": "node tools/test-history.ts",
    "pak": "node tools/pak-cli.js",
    "extract-fixture": "node tools/extract-fixture.ts",
    "diff-terrain": "node tools/diff-terrain.ts",
    "diff-objects": "node tools/diff-objects.ts",
    "diff-map": "node tools/diff-map.ts",
    "make-pwl": "node tools/make-pwl.ts",
    "script-api": "node tools/script-api.ts",
    "build-api": "node tools/build-api.ts",
    "object-shape": "node tools/object-shape.ts",
    "terrain-shape": "node tools/terrain-shape.ts",
    "unpack-data": "node tools/unpack-data.ts",
    "typecheck": "tsc --noEmit",
    "test": "node tools/test-all.ts",
    "test-e2e": "playwright test",
    "build:renderer": "node tools/build-renderer.ts",
    "harness": "npm run build:renderer && node tools/make-harness.js && node tools/serve-harness.js",
    "watch:renderer": "node tools/build-renderer.ts --watch",
    "object-schema": "node tools/object-schema.ts",
    "object-defaults": "node tools/object-defaults.ts",
    "test-defaults": "node tools/test-defaults.ts",
    "test-typespec": "node tools/test-typespec.ts"
  },
  "dependencies": {
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "electron": "^43.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2"
  }
}
